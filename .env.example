# Copy this file to .env and fill in what you have.
# Every integration is optional — the dashboard uses whatever is configured
# and falls back to CSV imports / manual entries for the rest.
# All keys should be READ-ONLY / VIEW-ONLY. This app never needs (and you
# should never grant) trade or withdrawal permission.

# ── Kraken ──────────────────────────────────────────────────────────────
# Create at: kraken.com → profile icon → Settings → API → Create API key
# Permissions to check:  Query funds,  Query closed orders & trades,
#                        Query ledger entries.   Nothing else.
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# ── Coinbase ────────────────────────────────────────────────────────────
# Create at: coinbase.com → (avatar) → Settings → API → Create API key
# (this opens the Coinbase Developer Platform / CDP portal).
# Choose "View (read-only)" permission only.
# You will get a key name like organizations/xxxx/apiKeys/yyyy and a
# private key (either a PEM block or a base64 Ed25519 string). Paste the
# PEM with \n in place of line breaks, in quotes, e.g.:
# COINBASE_API_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\nMHc...\n-----END EC PRIVATE KEY-----\n"
COINBASE_API_KEY_NAME=
COINBASE_API_PRIVATE_KEY=

# ── Phantom (self-custody) ──────────────────────────────────────────────
# No API key needed. Open Phantom → Bitcoin account → Receive, copy the
# address (starts with bc1...). If Phantom shows both a Native SegWit and
# a Taproot address, include both, comma-separated.
PHANTOM_BTC_ADDRESSES=

# ── Server ──────────────────────────────────────────────────────────────
PORT=3000
